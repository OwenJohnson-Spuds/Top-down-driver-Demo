  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  _dialoguePanel: {fileID: 1738824161}
  _dialogueText: {fileID: 956390357}
  _dialogueLines:
  - Howdy Driver, help a fella out and get me some ice cream
  - Here, I'll open the gate for you
  - Well, thank you kindly, Driver
  - Why don't you head west, all sorts of folks lookin' to get their hands on a frozen
    treat
  - Don't forget to pick up a package befor you leave
  - Remeber, you can only carry one package at a time
  _iceCreamGate: {fileID: 1634731527}
  _westGate: {fileID: 927629608}
